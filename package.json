{
  "name": "@otto-assistant/otto",
  "version": "0.1.2",
  "description": "Otto — terminal UI distribution wrapper for opencode + kimaki + mempalace",
  "type": "module",
  "bin": {
    "otto": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "keywords": [
    "otto",
    "opencode",
    "kimaki",
    "ai-agent",
    "distribution"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otto-assistant/otto.git"
  },
  "scripts": {
    "build": "rm -rf dist *.tsbuildinfo && tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "build:artifacts": "./scripts/build-local-artifacts.sh",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  }
}
